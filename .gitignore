# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.venv/
venv/
dist/
build/
*.egg

# Environment / secrets
backend/.env
.env
backend/.schwab_token.json
backend/.schwab_token.enc
# schwab-py may write a token file named with a URL-safe base64 app-key hash
-iLylvI50QuKOh87HJn5xOvlbXIOAqM_s0fZNpcXxDI=
# schwab-py OAuth temp files (written during auth flow, safe to delete)
backend/.schwab_tmp_*

# ML artifacts (large binary files — regenerated by training)
backend/ml/artifacts/*.joblib
backend/ml/artifacts/*.json
backend/ml/data/*.db

# Logs and generated scan output (runtime only)
logs/

# Temp / scratch files
0

# Frontend
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Claude internal
.claude/

# OS
.DS_Store
Thumbs.db

# Cloudflare tunnel
cloudflared*.exe
config.yml
